{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/klehmer/nimbusfab/pkg/ir/project",
  "$ref": "#/$defs/Project",
  "$defs": {
    "Component": {
      "properties": {
        "name": {
          "type": "string",
          "maxLength": 63,
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
        },
        "type": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": [
            "replicate",
            "composed"
          ]
        },
        "spec": {
          "type": "object"
        },
        "targets": {
          "items": {
            "$ref": "#/$defs/DeploymentTarget"
          },
          "type": "array",
          "minItems": 1
        },
        "refs": {
          "items": {
            "$ref": "#/$defs/ComponentRef"
          },
          "type": "array"
        },
        "policy": {
          "$ref": "#/$defs/ComponentPolicy"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "name",
        "type",
        "spec",
        "targets"
      ]
    },
    "ComponentPolicy": {
      "properties": {
        "serial": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ComponentRef": {
      "properties": {
        "component": {
          "type": "string"
        },
        "output": {
          "type": "string"
        },
        "as": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "component"
      ]
    },
    "Composition": {
      "properties": {
        "apiVersion": {
          "type": "string",
          "enum": [
            "infra.dev/v1alpha1"
          ]
        },
        "kind": {
          "type": "string",
          "maxLength": 63,
          "pattern": "^[A-Za-z][A-Za-z0-9]*$"
        },
        "schema": {
          "type": "object"
        },
        "template": {
          "$ref": "#/$defs/CompositionTpl"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "apiVersion",
        "kind",
        "schema",
        "template"
      ]
    },
    "CompositionTpl": {
      "properties": {
        "resources": {
          "items": {
            "$ref": "#/$defs/Component"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "DeploymentTarget": {
      "properties": {
        "cloud": {
          "type": "string",
          "maxLength": 63,
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
        },
        "region": {
          "type": "string"
        },
        "credentialRef": {
          "type": "string"
        },
        "spec": {
          "type": "object"
        },
        "primitives": {
          "items": {
            "$ref": "#/$defs/ResourcePrimitive"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "cloud",
        "region",
        "credentialRef"
      ]
    },
    "Project": {
      "properties": {
        "apiVersion": {
          "type": "string",
          "enum": [
            "infra.dev/v1alpha1"
          ]
        },
        "name": {
          "type": "string",
          "maxLength": 63,
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
        },
        "description": {
          "type": "string"
        },
        "stacks": {
          "additionalProperties": {
            "$ref": "#/$defs/Stack"
          },
          "type": "object"
        },
        "components": {
          "items": {
            "$ref": "#/$defs/Component"
          },
          "type": "array"
        },
        "compositions": {
          "items": {
            "$ref": "#/$defs/Composition"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "apiVersion",
        "name",
        "stacks"
      ]
    },
    "ResourcePrimitive": {
      "properties": {
        "id": {
          "type": "string"
        },
        "cloud": {
          "type": "string"
        },
        "tofuType": {
          "type": "string"
        },
        "tofuName": {
          "type": "string"
        },
        "attributes": {
          "type": "object"
        },
        "dependsOn": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "tags": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Stack": {
      "properties": {
        "name": {
          "type": "string",
          "maxLength": 63,
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
        },
        "vars": {
          "type": "object"
        },
        "stateBackend": {
          "$ref": "#/$defs/StateBackend"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "StateBackend": {
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "s3",
            "gcs",
            "azurerm",
            "pg",
            "local"
          ]
        },
        "config": {
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "kind"
      ]
    }
  }
}